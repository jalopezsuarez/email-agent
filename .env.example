# Copy to .env and fill in.
# Only the provider you use needs its API key.

# Microsoft Entra app registration
MS_CLIENT_ID=your-ms-app-client-id

# Optional absolute processing cutoffs (YYYYMMDD, UTC midnight)
# INBOX classification/moves start from this date onward.
AGENT_INBOX_FROM=20260419
# Sent Items learning starts from this date onward and expands incrementally
# if you move the date further into the past later.
AGENT_SENT_FROM=20260101

# LLM provider
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-claude-api-key
