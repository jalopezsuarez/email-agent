# Copy to .env and fill in.
# Only the provider you use needs its API key.

# Microsoft Entra app registration
MS_CLIENT_ID=your-ms-app-client-id

  # API keys
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-claude-api-key

# Optional overrides for the text model
# SERVICE_LLM_BASEURL=https://api.anthropic.com/v1
# SERVICE_LLM_APIKEY=your-claude-api-key
# SERVICE_LLM_API_VERSION=2023-06-01
# SERVICE_LLM_MODEL=claude-sonnet-4-20250514

# Optional overrides for embeddings
# SERVICE_EMBEDDINGS_BASEURL=https://api.openai.com/v1
# SERVICE_EMBEDDINGS_APIKEY=your-openai-api-key
# SERVICE_EMBEDDINGS_MODEL=text-embedding-3-small